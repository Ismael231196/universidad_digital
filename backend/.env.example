# ──────────────────────────────────────────────
# Universidad Digital – Variables de entorno
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el .env con credenciales reales al repositorio.
# ──────────────────────────────────────────────

# ── Aplicación ─────────────────────────────────
APP_ENV=development          # development | production
APP_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/universidad
APP_JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_32_caracteres
APP_JWT_EXPIRATION=60        # minutos
APP_COOKIE_SECURE=false      # true en producción (HTTPS)
APP_COOKIE_SAMESITE=lax      # lax | none (none en producción cross-site)
APP_CORS_ORIGINS=http://localhost:3000

# ── URL base del frontend ──────────────────────
# Se usa para construir el enlace de restablecimiento de contraseña.
# Acepta también la variable FRONTEND_URL por compatibilidad.
# Ejemplo: https://universidad-digital.vercel.app
APP_BASE_URL=http://localhost:3000

# ── Email – Mailtrap Email API (restablecimiento de contraseña) ────
# Mailtrap Email API permite capturar y enviar emails sin configuración SMTP.
#
# Cómo obtener las credenciales de Mailtrap Email API:
#   1. Regístrate en https://mailtrap.io (plan gratuito disponible)
#   2. Ve a "Email Testing" → tu Inbox → "API" (pestaña de integraciones)
#   3. Copia el API Token y el Inbox ID
#
MAILTRAP_API_TOKEN=<tu_mailtrap_api_token>
MAILTRAP_INBOX_ID=<tu_mailtrap_inbox_id>

# Remitente que verán los destinatarios
MAIL_FROM=no-reply@universidad-digital.com
