{
  "name": "universidad-digital-frontend",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:cypress": "cypress run",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:real": "cypress run --spec cypress/e2e/real-backend.cy.ts",
    "cypress:run:crud": "cypress run --spec cypress/e2e/crud-admin.cy.ts --config baseUrl=http://localhost:3001",
    "cypress:run:rbac": "cypress run --spec cypress/e2e/rbac-navigation.cy.ts --config baseUrl=http://localhost:3001",
    "cypress:run:grades": "cypress run --spec cypress/e2e/grades-crud.cy.ts --config baseUrl=http://localhost:3001",
    "cypress:run:hardening": "cypress run --spec cypress/e2e/auth-hardening.cy.ts --config baseUrl=http://localhost:3001",
    "cypress:run:pro": "cypress run --spec cypress/e2e/auth.cy.ts,cypress/e2e/auth-hardening.cy.ts,cypress/e2e/rbac-navigation.cy.ts,cypress/e2e/crud-admin.cy.ts,cypress/e2e/grades-crud.cy.ts --config baseUrl=http://localhost:3001",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "axios": "^1.7.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.3",
    "cypress": "^15.11.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9"
  }
}
